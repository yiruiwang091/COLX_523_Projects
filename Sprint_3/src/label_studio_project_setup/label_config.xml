<View>
  <!-- ===== Product context (read-only) ===== -->
  <View style="background: #f0f4ff; padding: 12px; border-radius: 6px; margin-bottom: 14px; font-size: 0.9em; color: #555;">
    <Text name="cat_info" value="$cat_chain"/>
    <Text name="rating_info" value="$overall"/>
  </View>

  <!-- ===== Title (annotate attribute mentions, NO sentiment) ===== -->
  <View style="margin-bottom: 14px;">
    <Header value="Title — highlight attribute mentions (no sentiment)"/>
    <Labels name="title_labels" toName="title_text">
      <Label value="attribute_mention" background="#17a2b8" textColor="white"/>
    </Labels>
    <Text name="title_text" value="$title"/>
    <TextArea name="title_attr_name" toName="title_text"
              perRegion="true"
              placeholder="Attribute name  e.g. size, weight, durability"
              maxSubmissions="1" editable="true"/>
  </View>

  <!-- ===== Description (annotate attribute mentions, NO sentiment) ===== -->
  <View style="margin-bottom: 14px;">
    <Header value="Description — highlight attribute mentions (no sentiment)"/>
    <Labels name="desc_labels" toName="desc_text">
      <Label value="attribute_mention" background="#17a2b8" textColor="white"/>
    </Labels>
    <Text name="desc_text" value="$description"/>
    <TextArea name="desc_attr_name" toName="desc_text"
              perRegion="true"
              placeholder="Attribute name  e.g. size, weight, durability"
              maxSubmissions="1" editable="true"/>
  </View>

  <!-- ===== Review Text (annotate spans WITH sentiment) ===== -->
  <View style="border: 2px solid #0066cc; padding: 12px; border-radius: 6px;">
    <Header value="Review Text — highlight attribute mentions and assign sentiment"/>
    <Labels name="review_labels" toName="review_text">
      <Label value="attribute_mention" background="#17a2b8" textColor="white"/>
    </Labels>
    <Text name="review_text" value="$reviewText"/>
    <View style="display:flex; gap:18px; margin-top:8px; flex-wrap:wrap;">
      <TextArea name="review_attr_name" toName="review_text"
                perRegion="true"
                required="true"
                rows="1"
                placeholder="attribute label (e.g., durability, size, cooling_performance)"/>
      <Choices name="sentiment" toName="review_text"
               perRegion="true"
               required="true"
               choice="single">
        <Choice value="positive"/>
        <Choice value="negative"/>
        <Choice value="neutral"/>
        <Choice value="unknown"/>
      </Choices>
    </View>
  </View>
</View>
